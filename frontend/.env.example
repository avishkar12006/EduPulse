# ── Copy this to .env (dev) or set as Vercel environment variables (prod) ────

# Your deployed backend URL on Render (NO trailing slash)
# Leave EMPTY in local dev — Vite proxy handles /api → localhost:8000 automatically
VITE_API_URL=https://edupulse-backend.onrender.com

# Gemini API key (only needed if you call Gemini directly from the browser)
VITE_GEMINI_API_KEY=AIzaSy...
