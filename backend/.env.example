# ── Copy this to .env and fill in your values ────────────────────────────────

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Connect → Drivers → copy URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/edupulse?retryWrites=true&w=majority

# JWT secret — pick any long random string (32+ chars)
JWT_SECRET=edupulse_super_secret_change_me_in_production_2024

# Google Gemini API key
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Email (choose ONE)
# Option A — Gmail (create App Password at myaccount.google.com/apppasswords)
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop

# Option B — SendGrid
SENDGRID_API_KEY=SG...

# Production only — URL of your deployed frontend (Vercel URL)
# Leave blank in development
FRONTEND_URL=https://edupulse.vercel.app

# Server port (Render sets this automatically)
PORT=8000

# Set to 'production' on Render. Leave blank locally.
NODE_ENV=
